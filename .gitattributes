# Auto detect text files and perform LF normalization
* text=auto

# TypeScript files
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf

# JSON files
*.json text eol=lf

# Markdown
*.md text eol=lf

# YAML
*.yml text eol=lf
*.yaml text eol=lf

# Docker
Dockerfile text eol=lf
.dockerignore text eol=lf

# Shell scripts
*.sh text eol=lf

# Config files
.env* text eol=lf
