# Kibana Configuration
KIBANA_URL=https://your-kibana-instance.com
KIBANA_API_KEY=your_api_key_here

# Alternative: Username/Password Authentication
# KIBANA_USERNAME=your_username
# KIBANA_PASSWORD=your_password

# Server Configuration
MCP_TRANSPORT=http
HTTP_PORT=3000
LOG_LEVEL=info

# Optional: Elasticsearch Direct Access (if needed)
# ELASTICSEARCH_URL=https://your-elasticsearch-instance.com
# ELASTICSEARCH_API_KEY=your_es_api_key
